      "destination": "home:active",
      "destination_reference": {
        "type": "product_screen_state",
        "screen_id": "home",
        "state": "active"
      },
      "acceptance": "The session can start"
    },
    {
      "id": "global-language-toggle",
      "screen": "home",
      "control_type": "toggle",
      "label": {
        "en-US": "中文",
        "zh-CN": "EN"
      },
      "feature_id": "language-switching",
      "action": "Switch product copy between English and Chinese",
      "destination": "home:idle",
      "destination_reference": {
        "type": "product_screen_state",
        "screen_id": "home",
        "state": "idle"
      },
      "acceptance": "A user can switch all product copy between English and Chinese without leaving the app"
    }
  ]
}
