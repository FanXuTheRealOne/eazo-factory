{
  "schema_version": "1.0",
  "controls": [
    {
      "id": "home-start-session",
      "screen": "home",
      "control_type": "button",
      "label": {
        "en-US": "Begin",
        "zh-CN": "开始"
      },
      "feature_id": "session",
